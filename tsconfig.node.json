{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    /* ⚠️ 注意：必须用 "bundler" 而非 "node"（即 node10）
       "moduleResolution": "node" 已在 TS 5.5+ 弃用，TS 7.0 将彻底移除。
       Vite 项目应使用 "bundler"。                                    */
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    /* ⚠️ 注意：不要添加 "baseUrl": "."
       baseUrl 已在 TS 5.5+ 弃用，TS 7.0 将彻底移除。
       没有 baseUrl 时，paths 的路径必须以 "./" 开头。*/
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["vite.config.ts"]
}