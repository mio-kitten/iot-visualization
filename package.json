{
  "name": "iot-visualization",
  "version": "1.0.0",
  "description": "自制IOT物联网显示面板",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "electron:start": "electron .",
    "electron:build": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.example.iot-visualization",
    "productName": "IoT可视化面板",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "portable"
    }
  },
  "dependencies": {
    "chart.js": "^4.4.1",
    "mqtt": "^5.3.5",
    "vue": "^3.3.13",
    "vue-chartjs": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.42",
    "@vitejs/plugin-vue": "^5.0.1",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vue-tsc": "^2.0.0"
  }
}